# Only track Markdown files
# Ignore everything by default
*

# But allow directories (so we can recurse into them)
!*/

# Allow all markdown files
!*.md

# Allow buildable reference specs in SignalPilot New Direction project
# (Python interface stubs, JSON Schema, policy YAML bundles).
# Scoped narrowly to this project's spec/ folder so other folders
# stay markdown-only.
!**/SignalPilot New Direction/spec/**/*.py
!**/SignalPilot New Direction/spec/**/*.json
!**/SignalPilot New Direction/spec/**/*.yaml
!**/SignalPilot New Direction/spec/**/*.yml

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Obsidian workspace files
.obsidian/
.obsidian-mac/
.trash/

# Temporary files
*.tmp
*.swp
*.swo
~$*

# VS Code settings
.vscode/

# Node modules
node_modules/

# Python cache
__pycache__/
*.pyc

# Logs
*.log

# Backup files
*.bak
*.old

# System files
Thumbs.db
Desktop.ini

# iCloud metadata
*.icloud

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
